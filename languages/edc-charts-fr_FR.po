msgstr "Shortcode"

#: includes/admin.php:36
#: includes/admin.php:87
msgid "Select or upload CSV"
msgstr "Sélectionner ou téléverser un CSV"

#: includes/admin.php:37
msgid "Use this file"
msgstr "Utiliser ce fichier"

#: includes/admin.php:38
msgid "File selected"
msgstr "Fichier sélectionné"

#: includes/admin.php:39
#: includes/admin.php:88
msgid "Remove"
msgstr "Supprimer"

#: includes/admin.php:40
msgid "Remove color"
msgstr "Supprimer la couleur"

#: includes/admin.php:41
