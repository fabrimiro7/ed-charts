#: includes/admin.php:8
msgid "EDC Chart Settings"
msgstr "Impostazioni grafico EDC"

#: includes/admin.php:20
#: includes/admin.php:307
msgid "Shortcode"
msgstr "Shortcode"

#: includes/admin.php:36
#: includes/admin.php:87
msgid "Select or upload CSV"
msgstr "Seleziona o carica CSV"

#: includes/admin.php:37
msgid "Use this file"
msgstr "Usa questo file"

#: includes/admin.php:38
msgid "File selected"
msgstr "File selezionato"

#: includes/admin.php:39
#: includes/admin.php:88
msgid "Remove"
msgstr "Rimuovi"

#: includes/admin.php:40
msgid "Remove color"
msgstr "Rimuovi colore"

#: includes/admin.php:41
#: includes/admin.php:170
msgid "Choose color"
msgstr "Scegli colore"

#: includes/admin.php:68
msgid "Data source"
msgstr "Fonte dati"

#: includes/admin.php:70
msgid "Google Sheets URL"
msgstr "URL Google Sheets"

#: includes/admin.php:71
msgid "Upload CSV file"
msgstr "Carica file CSV"

#: includes/admin.php:76
msgid "Google Sheets CSV URL"
msgstr "URL CSV Google Sheets"

#: includes/admin.php:79
msgid "In Google Sheets: File → Share → Publish to web → choose sheet → format CSV → publish → paste the link here."
msgstr "In Google Sheets: File → Condividi → Pubblica sul web → scegli foglio → formato CSV → pubblica → incolla il link qui."

#: includes/admin.php:84
msgid "Uploaded CSV file"
msgstr "File CSV caricato"

#: includes/admin.php:94
msgid "Chart type"
msgstr "Tipo di grafico"

#: includes/admin.php:96
msgid "Line"
msgstr "Linea"

#: includes/admin.php:97
msgid "Bar"
msgstr "Barre"

#: includes/admin.php:102
msgid "CSV has header row?"
msgstr "Il CSV ha una riga di intestazione?"

#: includes/admin.php:104
msgid "Yes"
msgstr "Sì"

#: includes/admin.php:105
msgid "No"
msgstr "No"

#: includes/admin.php:110
msgid "CSV delimiter"
msgstr "Separatore CSV"

#: includes/admin.php:112
msgid "Comma (,)"
msgstr "Virgola (,)"

#: includes/admin.php:113
msgid "Semicolon (;)"
msgstr "Punto e virgola (;)"

#: includes/admin.php:115
msgid "If your CSV looks \"all in one column\", try semicolon."
msgstr "Se il CSV appare \"tutto in una colonna\", prova il punto e virgola."

#: includes/admin.php:119
msgid "X column index (0-based)"
msgstr "Indice colonna X (da 0)"

#: includes/admin.php:121
msgid "Example: 0 means first column is used as labels (dates, names, etc.)"
msgstr "Esempio: 0 significa che la prima colonna è usata come etichette (date, nomi, ecc.)"

#: includes/admin.php:125
msgid "Series column indices (comma-separated, 0-based)"
msgstr "Indici colonne serie (separati da virgola, da 0)"

#: includes/admin.php:127
msgid "Example: \"1,2\" means second and third columns are chart series."
msgstr "Esempio: \"1,2\" significa che la seconda e terza colonna sono le serie del grafico."

#: includes/admin.php:131
msgid "Cache minutes"
msgstr "Minuti di cache"

#: includes/admin.php:133
msgid "How often the plugin refetches the CSV. Avoid fetching on every page load."
msgstr "Ogni quanto il plugin ricarica il CSV. Evita di recuperare a ogni caricamento pagina."

#: includes/admin.php:137
msgid "Text below X axis"
msgstr "Testo sotto l'asse X"

#: includes/admin.php:148
msgid "Free text shown below the horizontal axis of the chart."
msgstr "Testo libero mostrato sotto l'asse orizzontale del grafico."

#: includes/admin.php:152
msgid "Text beside Y axis"
msgstr "Testo laterale all'asse Y"

#: includes/admin.php:163
msgid "Free text shown to the left of the chart, beside the vertical axis (vertically centered)."
msgstr "Testo libero mostrato a sinistra del grafico, laterale all'asse verticale (centrato in altezza)."

#: includes/admin.php:167
msgid "Bar colors"
msgstr "Colori barre"

#: includes/admin.php:168
msgid "e.g. #1e3a5f or #1e3a5f, #2563eb, #3b82f6"
msgstr "es. #1e3a5f oppure #1e3a5f, #2563eb, #3b82f6"

#: includes/admin.php:171
msgid "Add color"
msgstr "Aggiungi colore"

#: includes/admin.php:174
msgid "For bar charts only. One color (e.g. #1e3a5f) or multiple comma-separated colors, one per series. Use the picker above to add a color. Leave empty for default palette."
msgstr "Solo per grafici a barre. Un colore (es. #1e3a5f) o più colori separati da virgola, uno per serie. Usa il selettore qui sopra per aggiungere un colore. Lascia vuoto per la palette predefinita."

#: includes/admin.php:88
msgid "Fit Y axis to data range"
msgstr "Adatta l'asse Y all'intervallo dei dati"

#: includes/admin.php:94
msgid "If enabled, the Y axis starts at (min value − 0.2) and ends at (max value + 0.2) instead of starting from 0."
msgstr "Se attivata, l'asse Y parte da (valore minimo − 0,2) e arriva a (valore massimo + 0,2) invece che partire da 0."

#: includes/helpers.php:83
msgid "No CSV file uploaded. Upload a CSV file in the chart settings."
msgstr "Nessun file CSV caricato. Carica un file CSV nelle impostazioni del grafico."

#: includes/helpers.php:87
msgid "CSV file not found or not readable."
msgstr "File CSV non trovato o non leggibile."

#: includes/helpers.php:94
msgid "The selected file is not a valid CSV."
msgstr "Il file selezionato non è un CSV valido."

#: includes/helpers.php:98
msgid "The CSV file is empty."
msgstr "Il file CSV è vuoto."

#: includes/helpers.php:103
msgid "Missing CSV URL. Set it in the chart settings."
msgstr "URL CSV mancante. Impostala nelle impostazioni del grafico."

#: includes/helpers.php:115
msgid "Failed to fetch CSV: %s"
msgstr "Impossibile recuperare il CSV: %s"

#: includes/helpers.php:120
msgid "CSV request failed with HTTP %s"
msgstr "Richiesta CSV fallita con HTTP %s"

#: includes/helpers.php:125
msgid "CSV response is empty."
msgstr "La risposta CSV è vuota."

#: includes/helpers.php:143
msgid "CSV contains no rows."
msgstr "Il CSV non contiene righe."

#: includes/helpers.php:175
msgid "Series %s"
msgstr "Serie %s"

#: includes/rest.php:35
msgid "Chart not found."
msgstr "Grafico non trovato."
